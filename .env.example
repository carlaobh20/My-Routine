# ===========================================================
# MODELO de variáveis de ambiente.
# Copie para .env.local (NÃO commite o .env.local).
# ===========================================================

# --- Supabase (públicas, podem ir pro frontend) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica

# --- VAPID: chave PÚBLICA vai pro frontend (push) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=sua_vapid_public_key

# ===========================================================
# As de baixo são SEGREDOS. Ficam só no servidor / Supabase,
# nunca no NEXT_PUBLIC_ e nunca no repositório.
# Configure-as no painel da Supabase (Edge Functions secrets)
# e na Vercel (Environment Variables), não aqui.
# ===========================================================

# VAPID chave PRIVADA (só na Edge Function)
VAPID_PRIVATE_KEY=sua_vapid_private_key
VAPID_SUBJECT=mailto:voce@exemplo.com

# Service role key (só no servidor / cron). NUNCA no frontend.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
